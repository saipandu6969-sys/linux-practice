 CREATE OR REPLACE VIEW 
 VW_ACTIVE_CUSTOMER_REVENUE AS
 SELECT
C.CUSTOMER_ID,
C.CUSTOMER_NAME,
C.CITY,
COUNT(F.ORDER_ID) AS TOTAL_ORDERS,
SUM(F.AMOUNT) AS TOTAL_REVENUE,

CASE 
    WHEN SUM(F.AMOUNT) > 20000 THEN 'PLATINUM'
    WHEN SUM(F.AMOUNT) > 10000 THEN 'GOLD'
    ELSE 'SILVER'
END AS REVENUE_CATEGORY

FROM DIM_CUSTOMER C
JOIN FACT_ORDERS F
ON C.CUSTOMER_ID = F.CUSTOMER_ID

WHERE C.IS_ACTIVE = TRUE

GROUP BY
C.CUSTOMER_ID,
C.CUSTOMER_NAME,
C.CITY

HAVING 
COUNT(F.ORDER_ID) > 2
AND SUM(F.AMOUNT) > 5000;   



