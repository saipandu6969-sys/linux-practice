----------Categorize customers into Platinum, Gold, Silver based on revenue-------------


SELECT D.CUSTOMER_NAME ,D.CITY,SUM(F.AMOUNT)AS TOTAL_REVENUE,COUNT(F.ORDER_ID) AS TOTAL_ORDERS,
CASE 
WHEN SUM(F.AMOUNT) >= 1500 
THEN 'PLATINUM'
WHEN SUM(F.AMOUNT) >=750 
THEN 'GOLD' 
ELSE 'SILVER' 
END AS REVENUE_CATEGEORY 
from DIM_CUSTOMER D JOIN FACT_ORDERS F 
ON 
D.CUSTOMER_ID = F.CUSTOMER_ID
GROUP BY D.CUSTOMER_NAME,D.CITY
ORDER BY TOTAL_REVENUE DESC;
----------Retrieve first and last order date per customer.----------------
SELECT * FROM FACT_ORDERS;
SELECT CUSTOMER_ID,MIN(ORDER_DATE)AS FIRST_ORDER,MAX(ORDER_DATE) AS LAST_ORDER 
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID;

----------Retrieve first and last order date per customer using join.----------------

SELECT D.CUSTOMER_NAME,MIN(F.ORDER_DATE)AS FIRST_ORDER ,MAX(F.ORDER_DATE) AS LATEST_ORDER
FROM DIM_CUSTOMER D JOIN FACT_ORDERS F 
ON 
D.CUSTOMER_ID=F.CUSTOMER_ID
GROUP BY CUSTOMER_NAME
ORDER BY FIRST_ORDER;
