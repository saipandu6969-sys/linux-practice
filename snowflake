CREATE OR REPLACE TABLE ORDER_PROCESS_METRICS (
 PROCESS_DATE DATE,
 TOTAL_STG_COUNT INT,
 VALID_COUNT INT,
 INVALID_COUNT INT,
 INSERT_COUNT INT,
 UPDATE_COUNT INT,
 PROCESS_TS TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
 
INSERT INTO ORDER_PROCESS_METRICS(
PROCESS_DATE,TOTAL_STG_COUNT,VALID_COUNT,
INVALID_COUNT,INSERT_COUNT,UPDATE_COUNT)
WITH INVALID_RECORDS AS (
SELECT S.ORDER_ID
FROM STG_ORDERS S
LEFT JOIN DIM_CUSTOMER D
ON S.CUSTOMER_ID = D.CUSTOMER_ID
WHERE S.AMOUNT <= 0
OR S.ORDER_DATE > CURRENT_DATE()
OR D.CUSTOMER_ID IS NULL),
VALID_RECORDS AS (
SELECT * 
FROM STG_ORDERS S
WHERE S.ORDER_ID NOT IN (SELECT ORDER_ID FROM INVALID_RECORDS)
),

INSERT_RECORDS AS (
SELECT V.ORDER_ID
FROM VALID_RECORDS V
LEFT JOIN FACT_ORDERS F
ON V.ORDER_ID = F.ORDER_ID
WHERE F.ORDER_ID IS NULL
),

UPDATE_RECORDS AS (
SELECT V.ORDER_ID
FROM VALID_RECORDS V
JOIN FACT_ORDERS F
ON V.ORDER_ID = F.ORDER_ID
WHERE F.AMOUNT <> V.AMOUNT
OR F.STATUS <> V.STATUS
)

SELECT 
CURRENT_DATE,
(SELECT COUNT(*) FROM STG_ORDERS),
(SELECT COUNT(*) FROM VALID_RECORDS),
(SELECT COUNT(*) FROM INVALID_RECORDS),
(SELECT COUNT(*) FROM INSERT_RECORDS),
(SELECT COUNT(*) FROM UPDATE_RECORDS);


